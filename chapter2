.r-acc  { background: rgba(138,90,202,0.4);  color: #C8A8F0; }
.r-bar  { width: 1px; height: 26px; background: rgba(201,168,76,0.25); margin: 0 2px; flex-shrink: 0; }

/* ── COMPARE ── */
.compare { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: 1.25rem 0; }
