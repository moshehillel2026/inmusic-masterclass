.e-bar { width: 100%; border-radius: 3px 3px 0 0; }
.e-lbl { font-family: var(--mono); font-size: 0.52rem; color: var(--muted); white-space: nowrap; position: absolute; bottom: -20px; text-align: center; width: 100%; }
