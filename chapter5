<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>פרק 5 — מקאמים, קצב ופיוז'ן תרבותי | מאסטרקלאס לירון</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Heebo:wght@300;400;500;700&family=Frank+Ruhl+Libre:wght@400;700;900&display=swap" rel="stylesheet">
<style>
/* ── RESET ── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

/* ── TOKENS ── */
:root {
  --gold:    #C9A84C;
  --gold-lt: #E8D08A;
  --gold-dk: #7A5F2A;
  --bg:      #0A0A08;
  --bg2:     #111109;
  --bg3:     #181814;
  --bg4:     #1E1C16;
  --border:  rgba(201,168,76,0.18);
  --text:    #E8E4D8;
  --muted:   #8A8470;
  --dim:     #5A5748;
  --teal:    #2E9E85;
  --blue:    #3A7BC8;
  --purple:  #8A5ACA;
  --red:     #C84040;
  --orange:  #C87830;
  --sans:  'Heebo', sans-serif;
  --serif: 'Frank Ruhl Libre', serif;
  --mono:  'IBM Plex Mono', monospace;
}

/* ── BASE ── */
html, body {
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  font-weight: 300;
  line-height: 1.85;
  direction: rtl;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
}
body { padding: 0 0 8rem; }

/* ── TOP NAV ── */
.topnav {
  background: rgba(10,10,8,0.94);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
  padding: 0.7rem clamp(1rem, 4vw, 2.5rem);
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 0.5rem;
  position: sticky; top: 0; z-index: 100;
}
.topnav-back { font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.1em; color: var(--gold-dk); text-decoration: none; transition: color 0.15s; }
.topnav-back:hover { color: var(--gold); }
.topnav-title { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.14em; color: var(--dim); }
.chapter-badge { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.12em; padding: 0.25rem 0.65rem; background: rgba(58,123,200,0.12); border: 1px solid rgba(58,123,200,0.3); border-radius: 2px; color: var(--blue); }

/* ── CENTER WRAPPER ── */
.page { max-width: 960px; margin: 0 auto; width: 100%; padding: 0 clamp(1rem, 4vw, 2.5rem); }

/* ── HERO ── */
.hero { padding: 4rem 0 3.5rem; border-bottom: 1px solid var(--border); position: relative; overflow: hidden; }
.hero::before {
  content: ''; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 50% at 50% -10%, rgba(58,123,200,0.06) 0%, transparent 70%),
    repeating-linear-gradient(0deg, transparent, transparent 48px, rgba(201,168,76,0.025) 48px, rgba(201,168,76,0.025) 49px);
  pointer-events: none;
}
.hero-eyebrow { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.2em; color: var(--gold-dk); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem; position: relative; }
.hero-eyebrow::before { content: ''; width: 28px; height: 1px; background: var(--gold-dk); }
.hero h1 { font-family: var(--serif); font-size: clamp(2.2rem, 6vw, 3.8rem); font-weight: 900; color: var(--gold-lt); line-height: 1.12; position: relative; }
.hero h1 em { font-style: normal; color: var(--text); font-weight: 300; }
.hero-sub { font-size: 1rem; color: var(--muted); max-width: 640px; margin: 1rem 0 0; font-weight: 300; position: relative; }
.toc-row { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 2rem; position: relative; }
.toc-chip { font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.08em; padding: 0.28rem 0.7rem; background: rgba(201,168,76,0.07); border: 1px solid var(--border); border-radius: 2px; color: var(--gold-dk); }

/* ── TOPIC ── */
.topic { margin-top: 5rem; padding-top: 2rem; border-top: 1px solid var(--border); }
.topic-header { display: flex; align-items: flex-start; gap: 1.25rem; margin-bottom: 2.5rem; flex-direction: row-reverse; flex-wrap: wrap; }
.topic-num-badge { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.1em; color: var(--gold-dk); background: var(--bg3); border: 1px solid var(--border); padding: 0.35rem 0.6rem; border-radius: 2px; flex-shrink: 0; margin-top: 5px; text-align: center; }
.topic-num-badge span { display: block; font-size: 1.5rem; font-weight: 600; color: var(--gold); line-height: 1; letter-spacing: 0; }
.topic-title { font-family: var(--serif); font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 700; color: var(--text); line-height: 1.2; }
.topic-title em { color: var(--gold-lt); font-style: normal; }
.topic-en { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); letter-spacing: 0.08em; margin-top: 0.35rem; direction: ltr; text-align: right; }

/* ── TYPOGRAPHY ── */
p { font-size: 0.96rem; margin-bottom: 1.2rem; font-weight: 300; line-height: 1.85; }
p:last-child { margin-bottom: 0; }
strong { color: var(--gold-lt); font-weight: 500; }
em { color: var(--muted); font-style: italic; }
.section-head { font-family: var(--sans); font-size: 0.75rem; font-weight: 500; letter-spacing: 0.14em; color: var(--gold); margin: 2.5rem 0 1rem; display: flex; align-items: center; gap: 0.75rem; flex-direction: row-reverse; }
.section-head::before { content: ''; flex: 1; height: 1px; background: var(--border); }

/* ── CALLOUTS ── */
.callout { margin: 1.25rem 0; padding: 0.9rem 1.15rem; border-radius: 4px; font-size: 0.875rem; line-height: 1.8; }
.callout.gold   { background: rgba(201,168,76,0.07);  border: 1px solid rgba(201,168,76,0.25);  color: var(--gold-lt); }
.callout.teal   { background: rgba(46,158,133,0.07);  border: 1px solid rgba(46,158,133,0.25);  color: #7DD4C0; }
.callout.blue   { background: rgba(58,123,200,0.07);  border: 1px solid rgba(58,123,200,0.25);  color: #90BFEE; }
.callout.red    { background: rgba(200,64,64,0.07);   border: 1px solid rgba(200,64,64,0.25);   color: #E09090; }
.callout.purple { background: rgba(138,90,202,0.07);  border: 1px solid rgba(138,90,202,0.25);  color: #C0A0E8; }
.callout.orange { background: rgba(200,120,48,0.07);  border: 1px solid rgba(200,120,48,0.3);   color: #E0A870; }
.callout strong { font-weight: 600; }
.callout-lbl { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.14em; opacity: 0.65; margin-bottom: 0.35rem; display: block; }

/* ── EXAMPLE BOX ── */
.example-box { background: var(--bg3); border: 1px solid rgba(201,168,76,0.2); border-right: 3px solid var(--gold); border-radius: 0 4px 4px 0; padding: 1rem 1.25rem; margin: 1rem 0; font-size: 0.875rem; line-height: 1.8; }
.example-box .ex-lbl { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.14em; color: var(--gold-dk); margin-bottom: 0.5rem; display: block; }
.example-box strong { color: var(--gold-lt); font-weight: 500; }
.example-box ol, .example-box ul { padding-right: 1.2rem; margin-top: 0.3rem; }
.example-box li { margin-bottom: 0.45rem; font-size: 0.86rem; }

/* ── PROMPT BLOCK ── */
.prompt-block { background: var(--bg4); border: 1px solid rgba(138,90,202,0.3); border-radius: 4px; padding: 1rem 1.25rem; margin: 1rem 0; font-family: var(--mono); font-size: 0.78rem; line-height: 1.75; color: #C0A8E8; direction: ltr; text-align: left; white-space: pre-wrap; word-break: break-word; overflow-wrap: break-word; max-width: 100%; }
.prompt-block .p-lbl { font-size: 0.58rem; letter-spacing: 0.14em; color: var(--purple); margin-bottom: 0.4rem; display: block; text-align: right; direction: rtl; }
.prompt-block .s { color: #9060C0; }
.prompt-block .l { color: #D4A843; }
.prompt-block .c { color: #3A7BC8; font-style: italic; }
.prompt-block .d { color: #2EB8A0; font-weight: 600; }

/* ── GRID / CARDS ── */
.card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(200px,100%), 1fr)); gap: 1rem; margin: 1.25rem 0; }
.info-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; padding: 1.15rem; }
.ic-tag { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; color: var(--gold-dk); margin-bottom: 0.4rem; display: block; direction: ltr; text-align: right; }
.ic-name { font-size: 0.95rem; font-weight: 600; margin-bottom: 0.35rem; }
.ic-desc { font-size: 0.83rem; color: var(--muted); line-height: 1.65; font-weight: 300; }
.ic-suno { font-family: var(--mono); font-size: 0.65rem; color: var(--purple); margin-top: 0.6rem; padding-top: 0.5rem; border-top: 1px solid var(--border); direction: ltr; text-align: left; }

/* ── TABLES ── */
.tbl-wrap { overflow-x: auto; width: 100%; -webkit-overflow-scrolling: touch; margin: 1rem 0; }
table { width: 100%; min-width: 480px; border-collapse: collapse; font-size: 0.855rem; }
th { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; color: var(--gold-dk); text-align: right; padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); font-weight: 400; }
td { padding: 0.65rem 0.75rem; border-bottom: 1px solid rgba(201,168,76,0.06); vertical-align: top; font-weight: 300; }
tr:hover td { background: rgba(201,168,76,0.025); }

/* ── STEP LIST ── */
.steps { list-style: none; margin: 1.25rem 0; }
.steps li { display: grid; grid-template-columns: 1fr 2rem; gap: 0.9rem; margin-bottom: 1.1rem; align-items: start; }
.sn { font-family: var(--mono); font-size: 0.68rem; color: var(--gold-dk); background: var(--bg3); border: 1px solid var(--border); width: 2rem; height: 2rem; display: flex; align-items: center; justify-content: center; border-radius: 2px; flex-shrink: 0; order: 2; margin-top: 2px; }
.st { font-size: 0.91rem; order: 1; line-height: 1.8; }
.st strong { color: var(--gold-lt); font-weight: 500; }

/* ── GROOVE GRID ── */
.groove-grid {
  display: flex; gap: 3px; margin: 1.5rem 0; direction: ltr;
  align-items: flex-end; height: 60px; overflow-x: auto;
  padding-bottom: 20px; -webkit-overflow-scrolling: touch;
}
.g-col { flex: 1; min-width: 38px; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; position: relative; }
.g-bar { width: 100%; border-radius: 3px 3px 0 0; }
.g-lbl { font-family: var(--mono); font-size: 0.5rem; color: var(--muted); position: absolute; bottom: -18px; white-space: nowrap; text-align: center; width: 100%; }
.g-on   .g-bar { height: 100%; background: rgba(201,168,76,0.55); }
.g-off  .g-bar { height: 58%; background: rgba(46,158,133,0.35); transform: translateX(3px); }
.g-kick .g-bar { height: 80%; background: rgba(200,64,64,0.5); }
.g-sub  .g-bar { height: 42%; background: rgba(138,90,202,0.35); transform: translateX(5px); }
.g-on   .g-lbl { color: var(--gold-dk); }
.g-off  .g-lbl { color: var(--teal); }
.g-kick .g-lbl { color: var(--red); }
.g-sub  .g-lbl { color: var(--purple); }

/* ── RHYTHM BLOCKS ── */
.rhythm-grid { direction: ltr; overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 1.25rem 0; padding-bottom: 0.5rem; }
.r-row { display: flex; align-items: center; gap: 3px; margin-bottom: 6px; min-width: 520px; }
.r-label { font-family: var(--mono); font-size: 0.6rem; color: var(--muted); width: 90px; flex-shrink: 0; text-align: right; padding-right: 8px; direction: rtl; }
.r-beat { width: 26px; height: 26px; border-radius: 3px; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 0.58rem; font-weight: 600; flex-shrink: 0; }
.r-D  { background: rgba(201,168,76,0.45);  color: var(--gold-lt); }
.r-T  { background: rgba(46,158,133,0.3);   color: var(--teal); }
.r-K  { background: rgba(138,90,202,0.3);   color: var(--purple); }
.r-O  { background: rgba(40,38,30,0.55);    color: var(--dim); border: 1px solid var(--border); }
.r-E  { background: rgba(200,64,64,0.4);    color: #F0A0A0; }
.r-bar { width: 1px; height: 26px; background: rgba(201,168,76,0.22); margin: 0 2px; flex-shrink: 0; }

/* ── MAQAM CARDS ── */
.maqam-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(220px,100%), 1fr)); gap: 1rem; margin: 1.25rem 0; }
.maqam-card { background: var(--bg2); border: 1px solid var(--border); border-radius: 4px; padding: 1.2rem; position: relative; overflow: hidden; }
.maqam-card::after { content: ''; position: absolute; top: 0; right: 0; width: 4px; height: 100%; }
.mq-rast::after     { background: var(--teal); }
.mq-bayati::after   { background: var(--purple); }
.mq-hijaz::after    { background: var(--gold); }
.mq-nahawand::after { background: var(--blue); }
.mq-name { font-family: var(--serif); font-size: 1.1rem; font-weight: 700; margin-bottom: 0.2rem; }
.mq-rast .mq-name     { color: var(--teal); }
.mq-bayati .mq-name   { color: var(--purple); }
.mq-hijaz .mq-name    { color: var(--gold-lt); }
.mq-nahawand .mq-name { color: var(--blue); }
.mq-arabic { font-size: 1.05rem; color: var(--muted); margin-bottom: 0.4rem; }
.mq-scale { font-family: var(--mono); font-size: 0.68rem; color: var(--muted); margin: 0.5rem 0; direction: ltr; text-align: left; line-height: 1.5; }
.mq-badge { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; padding: 0.2rem 0.5rem; border-radius: 2px; display: inline-block; margin-bottom: 0.5rem; }
.mq-rast .mq-badge     { background: rgba(46,158,133,0.12); color: var(--teal); border: 1px solid rgba(46,158,133,0.25); }
.mq-bayati .mq-badge   { background: rgba(138,90,202,0.12); color: var(--purple); border: 1px solid rgba(138,90,202,0.25); }
.mq-hijaz .mq-badge    { background: rgba(201,168,76,0.12); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); }
.mq-nahawand .mq-badge { background: rgba(58,123,200,0.12); color: var(--blue); border: 1px solid rgba(58,123,200,0.25); }
.mq-feel { font-size: 0.83rem; color: var(--text); font-weight: 300; line-height: 1.65; }
.mq-use  { font-size: 0.78rem; color: var(--muted); margin-top: 0.4rem; font-style: italic; }
.mq-suno { font-family: var(--mono); font-size: 0.63rem; color: var(--purple); margin-top: 0.6rem; padding-top: 0.5rem; border-top: 1px solid var(--border); direction: ltr; text-align: left; }

/* ── NUSACH CARDS ── */
.nusach-grid { display: flex; flex-direction: column; gap: 1rem; margin: 1.25rem 0; }
.nusach-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 4px; padding: 1.1rem 1.25rem; }
.nusach-head { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
.nusach-he { font-family: var(--serif); font-size: 1.15rem; font-weight: 700; color: var(--gold-lt); }
.nusach-en { font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.08em; color: var(--gold-dk); }
.nusach-mode { font-family: var(--mono); font-size: 0.6rem; color: var(--purple); background: rgba(138,90,202,0.1); border: 1px solid rgba(138,90,202,0.25); padding: 0.18rem 0.5rem; border-radius: 2px; }
.nusach-body { font-size: 0.875rem; font-weight: 300; line-height: 1.75; color: var(--text); }
.nusach-body strong { color: var(--gold-lt); font-weight: 500; }
.nusach-fusion { margin-top: 0.75rem; padding: 0.65rem 0.9rem; background: rgba(201,168,76,0.06); border: 1px solid rgba(201,168,76,0.2); border-radius: 3px; font-size: 0.83rem; color: var(--gold-lt); line-height: 1.65; }
.nusach-fusion::before { content: '⚡ שבירת הכלל: '; font-weight: 600; }

/* ── METHOD FLOW ── */
.method-flow { display: flex; flex-direction: column; gap: 0; margin: 1.25rem 0; }
.method-step { display: flex; align-items: stretch; gap: 0; flex-direction: row-reverse; }
.method-connector { display: flex; flex-direction: column; align-items: center; width: 40px; flex-shrink: 0; }
.method-node { width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 0.72rem; font-weight: 600; flex-shrink: 0; z-index: 1; border: 2px solid; }
.method-line { width: 2px; flex: 1; min-height: 24px; background: var(--border); }
.method-step:last-child .method-line { display: none; }
.method-content { flex: 1; padding: 0.2rem 0 1.5rem; padding-right: 1rem; }
.method-title { font-size: 0.92rem; font-weight: 600; color: var(--gold-lt); margin-bottom: 0.3rem; line-height: 1.35; margin-top: 6px; }
.method-desc { font-size: 0.875rem; color: var(--text); font-weight: 300; line-height: 1.75; }
.method-desc strong { color: var(--gold-lt); font-weight: 500; }
.step-n1 .method-node { background: rgba(46,158,133,0.15); border-color: var(--teal); color: var(--teal); }
.step-n2 .method-node { background: rgba(201,168,76,0.12); border-color: var(--gold); color: var(--gold); }
.step-n3 .method-node { background: rgba(138,90,202,0.15); border-color: var(--purple); color: var(--purple); }
.step-n4 .method-node { background: rgba(200,64,64,0.12); border-color: var(--red); color: var(--red); }
.step-n5 .method-node { background: rgba(58,123,200,0.15); border-color: var(--blue); color: var(--blue); }

/* ── MICROTONE VISUAL ── */
.micro-scale { display: flex; align-items: flex-end; gap: 2px; direction: ltr; margin: 1rem 0; overflow-x: auto; padding-bottom: 22px; -webkit-overflow-scrolling: touch; height: 80px; }
.ms-note { display: flex; flex-direction: column; align-items: center; justify-content: flex-end; min-width: 40px; flex: 1; position: relative; }
.ms-bar { width: 100%; border-radius: 3px 3px 0 0; }
.ms-lbl { font-family: var(--mono); font-size: 0.5rem; position: absolute; bottom: -20px; white-space: nowrap; text-align: center; width: 100%; }
.ms-whole    .ms-bar { height: 72%; background: rgba(201,168,76,0.5); }   .ms-whole    .ms-lbl { color: var(--gold); }
.ms-half     .ms-bar { height: 58%; background: rgba(201,168,76,0.35); }  .ms-half     .ms-lbl { color: var(--gold-dk); }
.ms-quarter  .ms-bar { height: 40%; background: rgba(138,90,202,0.45); }  .ms-quarter  .ms-lbl { color: var(--purple); }
.ms-west-eq  .ms-bar { height: 72%; background: rgba(46,158,133,0.45); }  .ms-west-eq  .ms-lbl { color: var(--teal); }
.ms-missing  .ms-bar { height: 8%;  background: rgba(200,64,64,0.2); border: 1px dashed rgba(200,64,64,0.4); } .ms-missing .ms-lbl { color: var(--red); }

/* ── CODE ── */
code { font-family: var(--mono); font-size: 0.82em; background: rgba(201,168,76,0.1); padding: 0.1em 0.35em; border-radius: 3px; color: var(--gold-lt); direction: ltr; display: inline-block; word-break: break-word; }

/* ── SEAL / COMPLETION BOX ── */
.completion-seal {
  margin-top: 4rem;
  padding: 3rem 2rem;
  background: var(--bg3);
  border: 1px solid rgba(201,168,76,0.3);
  border-radius: 8px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.completion-seal::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, rgba(201,168,76,0.06) 0%, transparent 70%);
  pointer-events: none;
}
.seal-title { font-family: var(--serif); font-size: clamp(1.4rem, 4vw, 2rem); font-weight: 900; color: var(--gold-lt); margin-bottom: 0.75rem; position: relative; }
.seal-sub { font-size: 0.95rem; color: var(--muted); max-width: 540px; margin: 0 auto 1.5rem; line-height: 1.85; position: relative; font-weight: 300; }
.seal-tags { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; position: relative; }
.seal-tag { font-family: var(--mono); font-size: 0.6rem; letter-spacing: 0.1em; padding: 0.28rem 0.7rem; background: rgba(201,168,76,0.08); border: 1px solid var(--border); border-radius: 2px; color: var(--gold-dk); }

/* ── CHAPTER FOOTER NAV ── */
.chapter-nav { margin-top: 5rem; padding: 1.75rem 0; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
.cnav-link { font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.08em; color: var(--gold-dk); text-decoration: none; transition: color 0.15s; }
.cnav-link:hover { color: var(--gold); }
.cnav-label { font-family: var(--mono); font-size: 0.58rem; color: var(--dim); letter-spacing: 0.12em; }

/* ── RESPONSIVE ── */
